# ─────────────────────────────────────────────
# LokKatha AI — .gitignore
# ─────────────────────────────────────────────

# === Dependencies ===
node_modules/
.pnp/
.pnp.js

# === Next.js ===
.next/
out/
build/
tsconfig.tsbuildinfo

# === Environment Variables ===
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# === IDE / Editor ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# === OS ===
.DS_Store
*.pem

# === Debug / Logs ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Python (backend/) ===
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/
*.egg

# Python env files (backend has its own .env)
backend/.env
backend/.env.*
!backend/.env.example

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking / linting
.mypy_cache/
.ruff_cache/

# Logs
*.log
logs/

# Backend runtime upload staging (keep dir via .gitkeep)
backend/uploads/*
!backend/uploads/.gitkeep

# === Testing ===
coverage/
.nyc_output/

# === Misc ===
*.tsbuildinfo

# === v0 sandbox internal files ===
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/

# === Vercel ===
.vercel/

# === Tool configs (contain API keys) ===
opencode.json
